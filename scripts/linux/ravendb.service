[Unit]
Description=RavenDB NoSQL Database
After=network.target

[Service]
LimitCORE=infinity
LimitNOFILE=65535
LimitRSS=infinity
LimitAS=infinity
LimitMEMLOCK=infinity
TasksMax=infinity
UMask=0027
StartLimitBurst=0
AmbientCapabilities=CAP_NET_BIND_SERVICE  
Restart=on-failure
Type=exec
TimeoutStopSec=300
User=RAVENDB_USERNAME
ExecStart=RAVENDB_PATH/run.sh

[Install]
WantedBy=multi-user.target

