{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "~/zig/zig",
            "args": [
                "cc",
                "-Wall",
                "-O0",
                "-g",
                "-fPIC",
                "-Iinc",
                "-target",
                "x86_64-linux-gnu",
                "../../libs/liburing/liburing-2.8.1-x64.a",
                "-o",
                "test-runner",
                "src/shared_all.c",
                "src/rvngetpalver.c",
                "src/posix/fileutils.c",
                "src/posix/geterrorstring.c",
                "src/posix/getsysteminformation.c",
                "src/posix/journal.c",
                "src/posix/mapping.c",
                "src/posix/pager.c",
                "src/posix/sync.c",
                "src/posix/ioring.c",
                "src/posix/virtualmemory.c",
                "src/posix/writefileheader.c",
                "src/posix/linuxonly.c",
                "test-linux.c"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}